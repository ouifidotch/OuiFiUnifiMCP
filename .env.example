# ── Unifi Cloud API ────────────────────────────────────────────────────────────
# Generate at: unifi.ui.com → Settings → API Keys
UNIFI_API_KEY=your_cloud_api_key_here

# ── Unifi Access API tokens (per site) — OPTIONAL ─────────────────────────────
# Only needed for sites that have Unifi Access installed (door readers, NFC, etc.)
# Generate in: Access → Settings → General → Advanced → API Token
#
# The variable name is derived from your site name:
#   "Main Office"            → UNIFI_ACCESS_TOKEN_MAIN_OFFICE
#   "Beach House"            → UNIFI_ACCESS_TOKEN_BEACH_HOUSE
#   "Warehouse - Building 2" → UNIFI_ACCESS_TOKEN_WAREHOUSE_BUILDING_2
#
# Run list_sites to see the exact slug for each of your sites (shown as "slug").
# Leave blank or omit entirely for sites without Unifi Access.

# UNIFI_ACCESS_TOKEN_YOUR_SITE_NAME=your_access_token_here
# UNIFI_ACCESS_TOKEN_ANOTHER_SITE=your_access_token_here
